OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM (OpenRouter)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=poolside/laguna-xs-2.1:free

# Генерация изображений (Pollinations)
IMAGE_BASE_URL=https://image.pollinations.ai/p/
IMAGE_MODEL=flux

# Авторизация / сессии
# COOKIE_SECURE=true — обязательно в проде (HTTPS); false — только для локального http
COOKIE_SECURE=false
# Время жизни сессии в часах (по умолчанию 168 = 7 дней)
SESSION_TTL_HOURS=168
# Имя cookie с токеном сессии
# SESSION_COOKIE_NAME=session_token
# Rate limiting: попыток на IP за окно (секунды)
# LOGIN_RATE_LIMIT=5
# REGISTER_RATE_LIMIT=3
# RATE_LIMIT_WINDOW_SECONDS=60

# Опционально
# SYSTEM_PROMPT="Your custom system prompt..."
# STYLE_MODIFIERS="Your custom style modifiers..."
# DATABASE_URL=sqlite+aiosqlite:///./alchemy.db
